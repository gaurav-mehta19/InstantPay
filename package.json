{
  "name": "payment",
  "private": true,
  "scripts": {
    "dev:all": "turbo dev",
    "dev:user": "yarn workspace user_app dev",
    "dev:dummy": "yarn workspace dummy_bank dev",
    "dev:webhook": "yarn workspace bank-webhook dev",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "start:user": "yarn workspace user_app start",
    "start:dummy": "yarn workspace dummy_bank start",
    "db:generate": "yarn workspace @repo/db db:generate",
    "db:migrate": "yarn workspace @repo/db db:migrate:dev",
    "db:migrate:deploy": "yarn workspace @repo/db db:migrate:deploy",
    "db:push": "yarn workspace @repo/db db:push",
    "db:studio": "yarn workspace @repo/db db:studio",
    "db:reset": "yarn workspace @repo/db db:reset"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "lucide-react": "^0.544.0"
  }
}
