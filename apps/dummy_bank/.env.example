# Dummy bank app

# Backend webhook endpoint for bank capture callback
BANK_WEBHOOK_URL="http://localhost:3003/hdfcWebhook"

# Must exactly match BANK WEBHOOK service secret
WEBHOOK_SIGNING_SECRET="replace-with-shared-webhook-secret"

# Webhook call timeout and retry settings.
# Keep these low for Vercel hobby/serverless limits, otherwise function can 504 before retries finish.
BANK_WEBHOOK_TIMEOUT_MS=2500
BANK_WEBHOOK_RETRY_COUNT=2
BANK_WEBHOOK_RETRY_DELAY_MS=500

# User app base URL used for post-success redirect
NEXT_PUBLIC_USER_APP_BASE_URL="http://localhost:3000"
BANK_WEBHOOK_URL="http://localhost:3003/hdfcWebhook"
WEBHOOK_SIGNING_SECRET="mywebhooksecret"
